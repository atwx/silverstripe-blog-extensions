{
    "name": "atwx/silverstripe-blog-extensions",
    "description": "Extension for silverstripe blog module with missing features",
    "type": "silverstripe-vendormodule",
    "keywords": [
        "silverstripe",
        "blog",
        "extensions"
    ],
    "license": "BSD-3-Clause",
    "require": {
        "silverstripe/framework": "^6.0",
        "silverstripe/blog": "^5.0",
        "symbiote/silverstripe-gridfieldextensions": "^5.1",
        "colymba/gridfield-bulk-editing-tools": "^5.1",
        "silverstripe/versioned": "^3.1",
        "lekoala/silverstripe-cms-actions": "^2.0"
    },
    "autoload": {
        "psr-4": {
            "ATWX\\BlogExtensions\\": "src/"
        }
    },
    "extra": {
        "expose": [
            "client/dist"
        ]
    },
    "minimum-stability": "dev",
    "prefer-stable": true,
    "config": {
        "allow-plugins": {
            "composer/installers": true,
            "silverstripe/vendor-plugin": true,
            "silverstripe/recipe-plugin": true
        }
    }
}
